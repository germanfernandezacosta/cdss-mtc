// src/lib/rag/vectorStore.ts
// Vector Store con better-sqlite3 — CORREGIDO v2.1-fix
// Garantiza document_id en cada RetrievedChunk

import Database from 'better-sqlite3';
import path from 'path';

export interface Chunk {
  chunk_id: string;
  document_id: string;
  domain: string;
  content: string;
  page_start: number;
  page_end: number;
  token_count: number;
  embedding: number[];
}

export interface RetrievedChunk {
  chunk_id: string;
  document_id: string;        // ← CRÍTICO: garantizado presente
  domain: string;
  content: string;
  page_start: number;
  page_end: number;
  token_count: number;
  similarity: number;
}

export class VectorStore {
  private db: Database.Database;
  private dimensions: number = 3072;

  constructor(dbPath?: string) {
    const finalPath = dbPath || path.join(process.cwd(), 'data', 'vectors', 'fukuoka-master.db');
    this.db = new Database(finalPath);
    this.db.pragma('journal_mode = WAL');
    this.init();
  }

  private init() {
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS chunks (
        chunk_id TEXT PRIMARY KEY,
        document_id TEXT NOT NULL,      -- ← NOT NULL para evitar NULLs
        domain TEXT,
        content TEXT,
        page_start INTEGER,
        page_end INTEGER,
        token_count INTEGER,
        embedding TEXT                  -- JSON array de 3072 floats
      );
      CREATE INDEX IF NOT EXISTS idx_chunks_domain ON chunks(domain);
      CREATE INDEX IF NOT EXISTS idx_chunks_document ON chunks(document_id);
    `);
  }

  /**
   * Inserta un chunk con embedding. 
   * document_id DEBE estar presente (ej: "bensky_materia_medica.pdf")
   */
  insertChunk(chunk: Chunk): void {
    if (!chunk.document_id || chunk.document_id.trim() === '') {
      throw new Error(`[VectorStore] document_id es obligatorio. chunk_id=${chunk.chunk_id}`);
    }

    const stmt = this.db.prepare(`
      INSERT INTO chunks (chunk_id, document_id, domain, content, page_start, page_end, token_count, embedding)
      VALUES (@chunk_id, @document_id, @domain, @content, @page_start, @page_end, @token_count, @embedding)
      ON CONFLICT(chunk_id) DO UPDATE SET
        document_id = excluded.document_id,
        domain = excluded.domain,
        content = excluded.content,
        embedding = excluded.embedding
    `);

    stmt.run({
      chunk_id: chunk.chunk_id,
      document_id: chunk.document_id,
      domain: chunk.domain,
      content: chunk.content,
      page_start: chunk.page_start,
      page_end: chunk.page_end,
      token_count: chunk.token_count,
      embedding: JSON.stringify(chunk.embedding)
    });
  }

  /**
   * Búsqueda por similitud coseno. 
   * CORREGIDO: document_id está explícitamente en SELECT y en el return.
   */
  search(queryEmbedding: number[], options: {
    domain?: string;
    limit?: number;
    minSimilarity?: number;
  } = {}): RetrievedChunk[] {
    const { domain, limit = 5, minSimilarity = 0.7 } = options;

    // Query que incluye document_id explícitamente
    let sql = `
      SELECT 
        chunk_id,
        document_id,        -- ← EXPLÍCITO: no usar * ni omitir
        domain,
        content,
        page_start,
        page_end,
        token_count,
        embedding
      FROM chunks
    `;

    const params: any[] = [];
    if (domain) {
      sql += ` WHERE domain = ?`;
      params.push(domain);
    }
    sql += ` ORDER BY chunk_id`; // fallback ordering; similitud calculada en memoria

    const rows = this.db.prepare(sql).all(...params) as any[];

    // Calcular similitud coseno en memoria
    const results: RetrievedChunk[] = rows.map(row => {
      const embedding: number[] = JSON.parse(row.embedding);
      const similarity = this.cosineSimilarity(queryEmbedding, embedding);

      return {
        chunk_id: row.chunk_id,
        document_id: row.document_id,     // ← GARANTIZADO: viene del SELECT
        domain: row.domain,
        content: row.content,
        page_start: row.page_start,
        page_end: row.page_end,
        token_count: row.token_count,
        similarity
      };
    });

    // Filtrar y ordenar
    return results
      .filter(r => r.similarity >= minSimilarity)
      .sort((a, b) => b.similarity - a.similarity)
      .slice(0, limit);
  }

  /**
   * DIAGNÓSTICO: Verifica integridad de document_id en toda la DB
   */
  diagnostic(): { total: number; withDocId: number; withoutDocId: number; sampleDocs: string[] } {
    const total = this.db.prepare('SELECT COUNT(*) as c FROM chunks').get() as { c: number };
    const withDocId = this.db.prepare(`SELECT COUNT(*) as c FROM chunks WHERE document_id IS NOT NULL AND document_id != ''`).get() as { c: number };
    const withoutDocId = this.db.prepare(`SELECT COUNT(*) as c FROM chunks WHERE document_id IS NULL OR document_id = ''`).get() as { c: number };
    const samples = this.db.prepare(`SELECT DISTINCT document_id FROM chunks WHERE document_id IS NOT NULL LIMIT 10`).all() as any[];

    return {
      total: total.c,
      withDocId: withDocId.c,
      withoutDocId: withoutDocId.c,
      sampleDocs: samples.map(s => s.document_id)
    };
  }

  private cosineSimilarity(a: number[], b: number[]): number {
    let dot = 0, normA = 0, normB = 0;
    for (let i = 0; i < a.length; i++) {
      dot += a[i] * b[i];
      normA += a[i] * a[i];
      normB += b[i] * b[i];
    }
    return dot / (Math.sqrt(normA) * Math.sqrt(normB));
  }

  close(): void {
    this.db.close();
  }
}

export default VectorStore;