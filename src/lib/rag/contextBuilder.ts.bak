// src/lib/rag/contextBuilder.ts
// RAG Context Builder — CORREGIDO v2.1-fix
// Lee document_id directamente del chunk, no de metadata

import { VectorStore, RetrievedChunk } from './vectorStore';

export interface RAGContext {
  context: string;           // Texto formateado para el prompt
  citations: Citation[];     // Array de citas estructuradas
  chunkCount: number;
  avgSimilarity: number;
}

export interface Citation {
  id: string;                // chunk_id
  document: string;          // Nombre legible del documento
  documentId: string;        // document_id original
  pageStart: number;
  pageEnd: number;
  similarity: number;
  excerpt: string;
}

// Mapeo de document_id → nombre legible para el clínico
const SOURCE_MAP: Record<string, string> = {
  'bensky_materia_medica.pdf': 'Bensky — Materia Medica',
  'bensky_formulas.pdf': 'Bensky — Formulas and Strategies',
  'nogueira_manual_acupuntura.pdf': 'Nogueira — Manual de Acupuntura',
  'van_nghi_canon.pdf': 'Van Nghi — Canon de Medicina China',
  'van_nghi_meridianos.pdf': 'Van Nghi — Meridianos',
  'chen_john_herb_drug.pdf': 'Chen J.K. — Herb-Drug Interactions',
  'chen_tina_pediatrics.pdf': 'Chen T.T. — Pediatrics',
  'ucla_east_west.pdf': 'UCLA — Center for East-West Medicine',
  'mskcc_integrative.pdf': 'MSKCC — Integrative Medicine',
  'cemtc_base.pdf': 'CEMeTC — Base Documental',
};

function getDisplayName(documentId: string | null | undefined): string {
  if (!documentId || documentId.trim() === '') {
    return 'Fuente desconocida';
  }

  // 1. Intentar match exacto
  if (SOURCE_MAP[documentId]) {
    return SOURCE_MAP[documentId];
  }

  // 2. Intentar match sin extensión
  const withoutExt = documentId.replace(/\.pdf$/i, '');
  if (SOURCE_MAP[withoutExt + '.pdf']) {
    return SOURCE_MAP[withoutExt + '.pdf'];
  }

  // 3. Intentar match parcial (ej: "bensky" → "Bensky...")
  const lower = documentId.toLowerCase();
  for (const [key, value] of Object.entries(SOURCE_MAP)) {
    if (lower.includes(key.replace('.pdf', '').toLowerCase())) {
      return value;
    }
  }

  // 4. Fallback: formatear el ID mismo
  return documentId
    .replace(/_/g, ' ')
    .replace(/\.pdf$/i, '')
    .replace(/\b\w/g, l => l.toUpperCase());
}

/**
 * Genera contexto RAG para inyectar en el prompt del LLM.
 * CORREGIDO: Usa chunk.document_id directamente (no metadata.source)
 */
export async function buildRAGContext(options: {
  query: string;
  domain?: string;
  maxChunks?: number;
  minSimilarity?: number;
  dbPath?: string;
}): Promise<RAGContext> {
  const {
    query,
    domain = 'clinical',
    maxChunks = 5,
    minSimilarity = 0.7,
    dbPath
  } = options;

  const store = new VectorStore(dbPath);

  try {
    // Generar embedding de la query (placeholder — reemplazar con tu embedder real)
    const queryEmbedding = await generateQueryEmbedding(query);

    // Recuperar chunks
    const chunks = store.search(queryEmbedding, {
      domain,
      limit: maxChunks,
      minSimilarity
    });

    // DIAGNÓSTICO: Loggear cada chunk para verificar document_id
    console.log(`[RAG] Recuperados ${chunks.length} chunks:`);
    chunks.forEach((chunk, i) => {
      console.log(`  [${i}] sim=${chunk.similarity?.toFixed(3)} | doc_id="${chunk.document_id}" | content="${chunk.content?.substring(0, 50)}..."`);
    });

    if (chunks.length === 0) {
      return {
        context: 'No se encontró contexto documental relevante para esta consulta.',
        citations: [],
        chunkCount: 0,
        avgSimilarity: 0
      };
    }

    // Construir contexto textual
    const contextParts: string[] = [];
    const citations: Citation[] = [];

    for (const chunk of chunks) {
      const displayName = getDisplayName(chunk.document_id);

      contextParts.push(
        `[FUENTE: ${displayName} | Págs. ${chunk.page_start}-${chunk.page_end}]\n${chunk.content}`
      );

      citations.push({
        id: chunk.chunk_id,
        document: displayName,
        documentId: chunk.document_id || 'unknown',
        pageStart: chunk.page_start,
        pageEnd: chunk.page_end,
        similarity: chunk.similarity,
        excerpt: chunk.content.substring(0, 200)
      });
    }

    const avgSim = chunks.reduce((sum, c) => sum + c.similarity, 0) / chunks.length;

    return {
      context: contextParts.join('\n\n---\n\n'),
      citations,
      chunkCount: chunks.length,
      avgSimilarity: avgSim
    };

  } finally {
    store.close();
  }
}

/**
 * Placeholder para generar embedding de query.
 * REEMPLAZAR con tu implementación real (OpenRouter, local, etc.)
 */
async function generateQueryEmbedding(query: string): Promise<number[]> {
  // TODO: Integrar con tu servicio de embeddings
  // Por ahora, genera un vector dummy de 3072 dims (NO usar en producción)
  console.warn('[RAG] Usando embedding dummy — reemplazar con embedding real');
  return new Array(3072).fill(0).map(() => Math.random() - 0.5);
}

export default buildRAGContext;