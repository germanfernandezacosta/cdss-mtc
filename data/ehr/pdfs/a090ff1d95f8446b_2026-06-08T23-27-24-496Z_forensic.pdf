{"patient":{"hash":"a090ff1d95f8446b","age":37,"gender":"F"},"session":{"id":0,"date":"2026-06-08T23:27:24.496Z","createdAt":"2026-06-08T23:27:59.682Z"},"practitioner":{},"clinical":{"symptoms":"Dolor abdominal tipo cólico - horas después de comer, alternancia estreñimiento-diarrea, meteorismo, fatiga persistente desde hace  meses, ansiedad con palpitaciones nocturnas, dolor cervical tensional.","syndrome":"Estancamiento de Qi del Hígado con deficiencia del Bazo y acumulación de humedad","rationale":"El diagnóstico se basa en la combinación de estancamiento de Qi del Hígado y deficiencia del Bazo, lo que causa síntomas como dolor abdominal, alternancia de estreñimiento y diarrea, y fatiga. La acupuntura en los puntos seleccionados ayuda a regular el Qi, fortalecer el Bazo y aliviar el dolor. La fórmula herbal Xiang Sha Liu Jun Zi Tang está diseñada para tonificar el Bazo, transformar la humedad y regular el Qi, lo que es coherente con la condición del paciente.","tongueNotes":"","pulseOverall":"","pointsExecution":"[{\"point\":\"6 MC (Neiguan)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"36 E (Zusanli)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"12 RM (Zhongwan)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"4 BP (Gongsun)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"4 IG (Hegu)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"}]","acupunctureNeedleCount":5,"herbalFormula":"Xiang Sha Liu Jun Zi Tang","referralNeeded":false},"kant":{"status":"green","score":100,"alerts":"[]","auditTrail":"\"2026-06-08T23:27:59.681Z\""},"rag":{},"system":{"foucaultVersion":"2.2","openrouterModel":"GPT-4o-mini","generationTimestamp":"2026-06-08T23:27:59.683Z","forensicHash":""}}