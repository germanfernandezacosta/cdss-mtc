{"patient":{"hash":"1f773b9c84b8971d","age":42,"gender":"F"},"session":{"id":0,"date":"2026-06-08T22:04:51.353Z","createdAt":"2026-06-08T22:05:16.377Z"},"practitioner":{},"clinical":{"symptoms":"Dolor de cabeza tensional en región temporal derecha, irritabilidad, digestión lenta, sensación de plenitud epigástrica, sueño interrumpido con despertares frecuentes.","syndrome":"Exceso de Yang de Hígado con vacío de Bazo y acumulación de humedad en el Estómago","rationale":"La cefalea tensional en la región temporal derecha sugiere un bloqueo del Qi del Hígado. La lengua rojiza con saburra amarillenta indica calor y humedad en el Estómago. El pulso cuerda en el Hígado sugiere estancamiento de Qi y el pulso débil en el Bazo indica vacío. Los puntos seleccionados ayudan a regular el Qi del Hígado, tonificar el Bazo y eliminar la humedad, mientras que la fórmula herbal apoya la digestión y tonifica el Bazo, aliviando así los síntomas del paciente.","tongueNotes":"","pulseOverall":"","pointsExecution":"[{\"point\":\"Hegu\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Zusanli\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Sanyinjiao\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Taichong\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Shangjuxu\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"}]","acupunctureNeedleCount":5,"herbalFormula":"Xiang Sha Liu Jun Zi Tang","referralNeeded":false},"kant":{"status":"green","score":100,"alerts":"[]","auditTrail":"\"2026-06-08T22:05:16.376Z\""},"rag":{},"system":{"foucaultVersion":"2.2","openrouterModel":"GPT-4o-mini","generationTimestamp":"2026-06-08T22:05:16.378Z","forensicHash":""}}