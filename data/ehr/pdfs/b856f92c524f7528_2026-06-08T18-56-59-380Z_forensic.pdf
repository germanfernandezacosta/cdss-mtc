{"patient":{"hash":"b856f92c524f7528","age":42,"gender":"F"},"session":{"id":0,"date":"2026-06-08T18:56:59.380Z","createdAt":"2026-06-08T18:57:35.187Z"},"practitioner":{},"clinical":{"symptoms":"Dolor de cabeza tensional en región temporal derecha, irritabilidad, digestión lenta, sensación de plenitud epigástrica, sueño interrumpido con despertares frecuentes.","syndrome":"Exceso de Yang de Hígado y vacío de Qi de Bazo, con estancamiento del Qi y calor en el estómago.","rationale":"La cefalea tensional en la región temporal derecha sugiere un estancamiento de Qi del hígado, exacerbado por la irritabilidad y la plenitud epigástrica. La lengua rojiza y el pulso cuerda reflejan un exceso de calor y Yang en el hígado. La combinación de puntos seleccionados busca liberar el Qi estancado, calmar el hígado y fortalecer el bazo para mejorar la digestión y el sueño. Las hierbas elegidas tonifican el bazo y regulan el Qi del hígado, ayudando a aliviar los síntomas.","tongueNotes":"","pulseOverall":"","pointsExecution":"[{\"point\":\"Hegu\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Zusanli\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Taichong\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Shangjuxu\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Yintang\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"}]","acupunctureNeedleCount":5,"herbalFormula":"Chai Hu (Radix Bupleuri), Bai Zhu (Rhizoma Atractylodis Macrocephalae), Ban Xia (Rhizoma Pinelliae), Sheng Jiang (Rhizoma Zingiberis Officinalis), Gan Cao (Radix Glycyrrhizae)","referralNeeded":false},"kant":{"status":"green","score":100,"alerts":"[]","auditTrail":"\"2026-06-08T18:57:35.185Z\""},"rag":{},"system":{"foucaultVersion":"2.2","openrou