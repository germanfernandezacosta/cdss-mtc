{"patient":{"hash":"b856f92c524f7528","age":42,"gender":"F"},"session":{"id":0,"date":"2026-06-08T21:31:15.518Z","createdAt":"2026-06-08T21:31:50.206Z"},"practitioner":{},"clinical":{"symptoms":"Dolor de cabeza tensional en región temporal derecha, irritabilidad, digestión lenta, sensación de plenitud epigástrica, sueño interrumpido con despertares frecuentes.","syndrome":"Exceso de Yang de Hígado con vacío de Bazo y estancamiento de Qi","rationale":"El diagnóstico sugiere un exceso de Yang en el Hígado que causa dolor de cabeza tensional y síntomas de irritabilidad. La lengua rojiza y el pulso cuerda indican calor y estancamiento en el Hígado. Los puntos propuestos ayudarán a liberar el Qi del Hígado, tonificar el Bazo y regular la digestión, aliviando así los síntomas. Las hierbas seleccionadas tonifican el Bazo y reducen el calor, ayudando a mejorar la digestión y el estado emocional del paciente.","tongueNotes":"","pulseOverall":"","pointsExecution":"[{\"point\":\"Hegu\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Zusanli\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Taichong\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Sanyinjiao\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"Shangjuxu\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"}]","acupunctureNeedleCount":5,"herbalFormula":"Bai Zhu (Atractylodes macrocephala), Huang Qin (Scutellaria baicalensis), Chai Hu (Bupleurum chinense), Gan Cao (Glycyrrhiza uralensis)","referralNeeded":false},"kant":{"status":"green","score":100,"alerts":"[]","auditTrail":"\"2026-06-08T21:31:50.203Z\""},"rag":{},"system":{"foucaultVersion":"2.2","openrouterModel":"GPT-4o-mini","generationTimestamp":"2026-06-08T21:31:50.207Z","forensicHash":""}}