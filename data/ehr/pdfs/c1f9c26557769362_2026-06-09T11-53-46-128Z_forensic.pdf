{"patient":{"hash":"c1f9c26557769362","age":37,"gender":"F"},"session":{"id":0,"date":"2026-06-09T11:53:46.128Z","createdAt":"2026-06-09T11:54:13.322Z"},"practitioner":{},"clinical":{"symptoms":"Dolor abdominal tipo cólico - horas después de comer, alternancia estreñimiento-diarrea, meteorismo, fatiga persistente desde hace meses, ansiedad con palpitaciones nocturnas, dolor cervical tensional.","syndrome":"Estancamiento de Qi del Hígado con deficiencia del Bazo","rationale":"El esquema de puntos propuesto está diseñado para regular el Qi del Hígado, fortalecer el Bazo y aliviar el dolor abdominal, que son fundamentales en el tratamiento del síndrome de intestino irritable. Las hierbas seleccionadas también están orientadas a regular el Qi y fortalecer el Bazo, siendo seguras y efectivas en este contexto. Se evitan los puntos y hierbas que puedan interactuar negativamente con el historial del paciente y su alergia a la penicilina.","tongueNotes":"Cuerpo lingual de borde dentado, color pálido-rosado con zonas laterales ligeramente enrojecidas. Saburra blanca gruesa y húmeda en raíz. Venas sublinguales ligeramente distendidas.","pulseOverall":"Global: tenso (弦) y ligeramente veloz (数). Izquierda: Guan prominente y tenso (exceso de Hígado). Derecha: Guan débil y hondo (deficiencia de Bazo). Chi bilateral profundo y fino (Riñón).","pointsExecution":"[{\"point\":\"6 MC (Neiguan)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"36 E (Zusanli)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"12 RM (Zhongwan)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"4 BP (Gongsun)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"},{\"point\":\"18 H (Yintang)\",\"location\":\"\",\"technique\":\"\",\"depth\":\"\",\"manipulation\":\"\",\"duration\":\"\"}]","acupunctureNeedleCount":5,"herbalFormula":"Bupleurum (Chai Hu), Pueraria (Ge Gen), Peonia blanca (Bai Shao), Jengibre fresco (Sheng Jiang)","referralNeeded":false,"referralReason":"Paciente con anticoagulante oral directo (DOAC)."},"kant":{"status":"green","score":92.5,"alerts":"[{\"ruleId\":\"KANT-AC-DOAC\",\"severity\":\"AMARILLO\",\"category\":\"ANTICOAGULANT\",\"message\":\"Paciente con anticoagulante oral directo (DOAC).\"}]","contraindications":"[]","auditTrail":"[\"AHPRA:advertisingRestrictions:evaluated\",\"AHPRA:scopeOfPractice:evaluated\",\"AHPRA:mandatoryReferral:evaluated\",\"RULE:anticoagulantPrecautions:evaluated\"]"},"rag":{},"system":{"foucaultVersion":"2.2","openrouterModel":"GPT-4o-mini","generationTimestamp":"2026-06-09T11:54:13.322Z","forensicHash":""}}